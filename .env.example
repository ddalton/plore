# pgvector
DATABASE_URL=postgresql://plore:plore@localhost:5432/maui_registry

# LiteLLM gateway (OpenAI-compatible)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sk-plore-local
CHAT_MODEL=taalas-llama        # LiteLLM route -> taalas-proxy (llama3.1-8B)
EMBED_MODEL=bge-small          # LiteLLM route -> Ollama all-minilm (384-dim)
EMBED_DIM=384

# Retrieval
TOP_K=5
PROJECT_ID=awc

# Ingestion source (one of):
#  - SPECS_DIR: a directory with <service>/openapi.yaml (e.g. the awc-core repo's api/)
#  - AWC_MCP_URL: fetch specs from awc-mcp's get_api_specs (cluster-native)
SPECS_DIR=../awc-core/api
AWC_MCP_URL=
AWC_MCP_TOKEN=
ENRICH_DESCRIPTIONS=true        # LLM-enrich operation descriptions at ingest (best-effort)

# Execution target (leave AWC_API_BASE empty for dry-run mode)
AWC_API_BASE=
AWC_API_VERIFY_TLS=false
# Auth: either a ready bearer token, or an access key plore exchanges for one.
AWC_API_TOKEN=
AWC_ACCESS_KEY_ID=
AWC_ACCESS_KEY_SECRET=

# Artifact offload (leave MINIO_ENDPOINT empty to summarize binary responses inline)
MINIO_ENDPOINT=                 # host:port, no scheme (e.g. minio:9000)
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=plore-artifacts
MINIO_SECURE=false
