# pgvector
DATABASE_URL=postgresql://plore:plore@localhost:5432/maui_registry

# LiteLLM gateway (OpenAI-compatible)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=sk-plore-local
CHAT_MODEL=taalas-llama
EMBED_MODEL=bge-small
EMBED_DIM=384

# Retrieval
TOP_K=3
PROJECT_ID=awc

# Ingestion source: a directory with <service>/openapi.yaml (e.g. the awc-core repo's api/)
SPECS_DIR=../awc-core/api

# Execution target (leave AWC_API_BASE empty for dry-run mode)
AWC_API_BASE=
AWC_API_TOKEN=
